{
  "name": "@gitinspect/cli",
  "version": "0.1.1",
  "bin": {
    "gitinspect": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "dev": "bun run --watch src/index.ts",
    "check-types": "tsc --noEmit",
    "prepublishOnly": "bun run build && bun run check-types && cd ../.. && bun run test -- tests/cli-*.test.ts",
    "publish:dry-run": "bun publish --dry-run"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@mariozechner/pi-ai": "^0.62.0",
    "clipboardy": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
