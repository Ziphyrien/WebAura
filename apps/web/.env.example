# Optional server-side token used by the public GitHub proxy at /api/github/*.
# Leave unset locally unless you want signed-out public metadata reads to proxy through the server.
GITHUB_PROXY_TOKEN=github_pat_your_proxy_token_here

# Enables the client-side public GitHub proxy fallback.
# Keep this false unless GITHUB_PROXY_TOKEN is configured on the server.
VITE_GITHUB_PROXY_ENABLED=false
