{
  "name": "just-github",
  "version": "0.1.0",
  "description": "An fs-like API for reading files from GitHub repositories — without cloning",
  "license": "MIT",
  "files": [
    "src"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./cache": "./src/cache.ts",
    "./github-client": "./src/github-client.ts",
    "./github-fs": "./src/github-fs.ts",
    "./github-http": "./src/github-http.ts",
    "./github-rate-limit": "./src/github-rate-limit.ts",
    "./refs": "./src/refs.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "just-bash": "^2.14.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
