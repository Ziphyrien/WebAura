{
  "extends": "@firefly/config/tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "paths": {
      "@firefly/extensions/*": ["./src/*"],
      "@firefly/db": ["../db/src/index.ts"],
      "@firefly/pi/*": ["../pi/src/*"],
      "@firefly/ui/*": ["../ui/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules"]
}
