{
  "extends": "@gitaura/config/tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "noImplicitAny": false,
    "noUncheckedIndexedAccess": false,
    "paths": {
      "@gitaura/ui/*": ["./src/*"],
      "@gitaura/pi/*": ["../pi/src/*"],
      "@gitaura/db": ["../db/src/index.ts"],
      "@gitaura/db/session-leases": ["../db/src/session-leases.ts"],
      "@gitaura/db/session-runtime": ["../db/src/session-runtime.ts"],
      "@/navigation/*": ["../../apps/web/src/navigation/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules"]
}
